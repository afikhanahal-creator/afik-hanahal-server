# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service-role secret key (Settings → API → Project API keys → service_role)
# This key bypasses RLS — keep it server-side only, never in the browser.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin authentication ───────────────────────────────────────────────────────
# Must match the password hard-coded in App.jsx PasswordPrompt (AFIKhanahal2026)
ADMIN_TOKEN=AFIKhanahal2026

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://afikhanahal.co.il,https://www.afikhanahal.co.il

# ── WhatsApp Business API ──────────────────────────────────────────────────────
WA_META_TOKEN=EAAn...
WA_PHONE_NUMBER_ID=1160230953835065
WA_VERIFY_TOKEN=AFIKhanahal2026
# Set to "false" to disable the AI bot (still receive webhooks)
WA_BOT_ENABLED=true

# ── Meta Conversions API ───────────────────────────────────────────────────────
META_CAPI_TOKEN=EAAO...
META_PIXEL_ID=1341264237748951

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Green API — WhatsApp follow-up after form submission ──────────────────────
# Get from: https://app.green-api.com → your instance → Settings
WA_GREENAPI_INSTANCE=7107XXXXXXX
WA_GREENAPI_TOKEN=your_apiTokenInstance_here
WA_GREENAPI_URL=https://api.green-api.com
# Message template sent to the lead (supports {name} placeholder)
WA_FOLLOWUP_TEMPLATE=היי {name}, תודה שפנית לאפיק הנחל! נחזור אליך בהקדם 🏡
# Delay before sending follow-up (minutes, default: 2)
WA_FOLLOWUP_DELAY_MIN=2

# ── Email notifications (Gmail SMTP) ──────────────────────────────────────────
# 1. Go to Google Account → Security → 2-Step Verification → App Passwords
# 2. Create a password for "afik-hanahal"
# 3. Paste the 16-char password below (no spaces)
GMAIL_USER=afik.hanahal@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Email address to receive new lead notifications
ADMIN_NOTIFY_EMAIL=afik.hanahal@gmail.com

# ── Cloudinary (video hosting) ────────────────────────────────────────────────
# Videos are the heaviest objects for storage + egress, so they are NOT stored
# in Supabase. /api/upload/video uploads to Cloudinary's video CDN instead.
# Create an UNSIGNED upload preset: Cloudinary dashboard → Settings → Upload →
# Upload presets → Add → Signing Mode: Unsigned.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
# Max accepted upload size in MB (applies to Cloudinary + the escape hatch below)
VIDEO_MAX_MB=150
# Escape hatch: set to "true" to keep storing videos in Supabase Storage when
# Cloudinary is NOT configured. Leave unset/false to return a guiding error.
# ALLOW_SUPABASE_VIDEO=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
